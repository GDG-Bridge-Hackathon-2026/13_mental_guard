PORT=4000
NODE_ENV=development

# Postgres connection string
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Google Cloud Storage
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket
GCS_CLIENT_EMAIL=your-service-account@your-gcp-project-id.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# ML service
ML_SERVICE_URL=
ML_SERVICE_TIMEOUT_MS=15000

# Firebase Web API Key (used by scripts/gen-token.ts)
FIREBASE_WEB_API_KEY=

# Firebase Admin
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# GCP Speech-to-Text
GCP_STT_LANGUAGE=ko-KR
GCP_STT_SAMPLE_RATE=48000
GCP_STT_ENCODING=WEBM_OPUS
GCP_STT_TIMEOUT_MS=10000

# CORS / WebSocket origin allowlist.
# Keep production domains explicit. Add local origins only for development.
CORS_ORIGINS=https://hkh-beta.vercel.app,http://localhost:3000,http://localhost:3001
